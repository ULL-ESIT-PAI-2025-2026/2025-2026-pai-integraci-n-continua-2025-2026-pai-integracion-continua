  "description": "Canvas API. Geometric Figures",
  "private": true,
  "main": "index.js",
  "scripts": {
    "docs": "typedoc",
    "docs:serve:bg": "nohup npx http-server docs -p 8081 > docs-server.log 2>&1 &",
